# Credenciales de la cuenta bot en mairenawiki.es
# Necesaria para publicar comentarios desde la app (la wiki no permite edición anónima)
#
# Pasos para obtenerlas:
#   1. Pedir a los admins de mairenawiki.es que creen una cuenta "MairenaFotosBot"
#      con permisos de edición en el grupo "Usuarios"
#   2. O bien, ir a Special:BotPasswords en la wiki con una cuenta admin
#      y crear un bot password con permiso "Edit existing pages"
#   3. Copiar este archivo como .env.local y rellenar los valores

WIKI_BOT_USER=MairenaFotosBot
WIKI_BOT_PASS=la-contraseña-del-bot
